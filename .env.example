# BPSTracker configuration
# Copy to .env and adjust before first start.

APP_NAME=BPSTracker

POSTGRES_DB=bpstracker
POSTGRES_USER=bpstracker
POSTGRES_PASSWORD=bpstracker_dev_password
DATABASE_URL=postgresql+psycopg://bpstracker:bpstracker_dev_password@postgres:5432/bpstracker

FRONTEND_PORT=5173
VITE_API_BASE_URL=same-origin
# Generate a long random value before real use: openssl rand -hex 32
# Do not change after production start: it encrypts Shelly passwords and Admin 2FA secrets.
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=720
FRONTEND_ORIGIN=*

# No application users or passwords are stored here.
# On a fresh database, open the web interface and create the initial admin account in the install screen.

# Polling safety defaults
POLLING_LOOP_SECONDS=5
SHELLY_TIMEOUT_SECONDS=5
SHELLY_MAX_CONCURRENCY=4

