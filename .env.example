# BPSTracker configuration
# Copy to .env and adjust before first start.

APP_NAME=BPSTracker

POSTGRES_DB=bpstracker
POSTGRES_USER=bpstracker
# Generate a database password before real use: openssl rand -base64 32
POSTGRES_PASSWORD=change-me-database-password
DATABASE_URL=postgresql+psycopg://bpstracker:change-me-database-password@postgres:5432/bpstracker

FRONTEND_PORT=5173
VITE_API_BASE_URL=same-origin
# Generate a long random value before real use: openssl rand -hex 32
# Do not change after production start: it encrypts Shelly passwords and Admin 2FA secrets.
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=720
# Browser JWTs are stored in HttpOnly cookies. Set AUTH_COOKIE_SECURE=true for HTTPS-only deployments.
AUTH_COOKIE_NAME=bpstracker_access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
# Recommended production mode is same-origin via nginx. For cross-origin dev, set explicit origins
# such as http://localhost:5173 instead of '*', otherwise credentialed CORS cookies are disabled.
FRONTEND_ORIGIN=*

# No application users or passwords are stored here.
# On a fresh database, open the web interface and create the initial admin account in the install screen.

# Polling safety defaults
POLLING_LOOP_SECONDS=5
SHELLY_TIMEOUT_SECONDS=5
SHELLY_MAX_CONCURRENCY=4
